{
  "[fish]": {
    "editor.defaultFormatter": "ndonfris.fish-lsp",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[snippets]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[xml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "files.associations": {
    ".chezmoiignore": "ignore",
    ".chezmoiremove": "ignore",
    ".shellcheckrc": "ini",
    "*.desktop": "ini",
    "*.elv.tmpl": "elvish",
    "*.env.tmpl": "dotenv",
    "*.fish.tmpl": "fish",
    "*.json.tmpl": "go-template",
    "*.plist": "xml",
    "*.plist.tmpl": "xml",
    "*.ps1.tmpl": "powershell",
    "*.sh.tmpl": "shellscript",
    "*.sublime-syntax": "yaml",
    "*.toml.tmpl": "toml",
    "*.yaml.tmpl": "yaml",
    "*.yml.tmpl": "yaml",
    "*.zsh.tmpl": "shellscript",
    "**/.chezmoitemplates/zsh/**": "shellscript",
    "**/*_dot_ssh/*_config.d/*.conf": "ssh_config",
    "**/*_dot_ssh/*_config.d/*.conf.tmpl": "ssh_config",
    "**/*_dot_ssh/*config": "ssh_config",
    "**/*_dot_ssh/*config.tmpl": "ssh_config",
    "**/dot_config/*_bat/config": "plaintext",
    "**/dot_config/*_carapace/*_overlays/*.yaml": "yaml",
    "**/dot_config/*_carapace/*_specs/*.yaml": "yaml",
    "**/dot_config/*_carapace/*_variables/*.yaml": "yaml",
    "**/dot_config/*_fd/ignore": "ignore",
    "**/dot_config/*_git/*_conf.d/*.gitconfig.tmpl": "gitconfig",
    "**/dot_config/*_git/*_conf.d/*.inc": "gitconfig",
    "**/dot_config/*_git/*_conf.d/*.inc.tmpl": "gitconfig",
    "**/dot_config/*_git/*_config": "gitconfig",
    "**/dot_config/*_git/ignore": "ignore",
    "**/dot_config/*_go/*env.tmpl": "dotenv",
    "**/dot_config/*_homebrew/*_config/*_op_sudo_askpass.tmpl": "shellscript",
    "**/dot_config/*_litecli/config.tmpl": "ini",
    "**/dot_config/*_rainbow/*.cfg": "plaintext",
    "**/dot_config/*_zsh/*_functions/**": "shellscript",
    "**/dot_local/*_share/*_flatpak/overrides/**": "ini",
    "ansible.cfg.tmpl": "ini",
    "dot_bashrc": "shellscript",
    "dot_wslconfig": "ini",
    "dot_zshrc": "shellscript",
  },
  "gitconfig-lsp.format.gitattributes.tabSize": 16,
  "go-template.patterns": [
    "**/*.tmpl",
    "**/.chezmoiignore",
    "**/.chezmoiremove",
    "**/.chezmoitemplates/**/*",
    "**/modify_*",
  ],
  "nushellLanguageServer.includeDirs": [
    "./home/dot_config/exact_private_nushell/modules",
  ],
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "yaml.schemas": {
    "./schemas/generated/chezmoiconfig.json": "home/.chezmoi.yaml.tmpl",
    "./schemas/generated/chezmoidata.json": "**/{.chezmoidata.yaml,.chezmoidata/**/*}",
    "./schemas/generated/chezmoiexternals.json": "home/.chezmoiexternals/**/*",
    "./schemas/vendor/lima.json": "home/dot_config/private_lima/{*/lima,_config/default}.yaml{,.tmpl}",
    "./schemas/generated/eza-theme.json": "home/dot_config/*_eza/theme.yml",
    "https://carapace.sh/schemas/command.json": "home/dot_config/*_carapace/*_{specs,overlays}/*.yaml{,.tmpl}",
    "https://github.com/sharkdp/vivid/raw/refs/heads/master/schemas/filetypes.json": "home/dot_config/vivid/filetypes.yml{,.tmpl}",
    "https://github.com/sharkdp/vivid/raw/refs/heads/master/schemas/theme.json": "home/dot_config/vivid/themes/*",
  },
  "fish-lsp.initializationOptions": {
    "fish_lsp_prefer_builtin_fish_commands": true,
  },
  "go-template.languages": ["fish"],
  "json.schemas": [
    {
      "fileMatch": ["deno.jsonc"],
      "schema": { "allowTrailingCommas": true },
      "url": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    },
  ],
}
